# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
env/
venv/
.Python

# ── Credentials & secrets (NEVER commit these) ──────────────────────────────
.env
*.json                    # catches any accidentally saved service account keys
!.env.example             # keep the example template in git

# ── Data exports (can be large; regenerate from BigQuery) ──────────────────
data/*.csv
data/*.parquet

# ── Terraform ───────────────────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.backup
crash.log

# ── dbt ─────────────────────────────────────────────────────────────────────
target/
dbt_packages/
logs/

# ── OS / editor ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
