# ==============================================================================
# NYC 311 Data Pipeline - Environment Variables Template
# ==============================================================================
# INSTRUCTIONS:
# 1. Copy this file and rename it to '.env' (do not commit '.env' to git)
# 2. Replace the placeholder values below with your actual GCP resource names.
# ==============================================================================

# 1. Google Cloud Configuration
# Your unique Google Cloud Project ID (e.g., my-gcp-project-12345)
GCP_PROJECT_ID="your_google_cloud_project_id"

# The GCP region where your resources will be deployed (e.g., us-central1)
GCP_REGION="us-central1"

# 2. Data Lake (Google Cloud Storage)
# The globally unique name for your GCS bucket created via Terraform
BUCKET_NAME="your_globally_unique_bucket_name"

# 3. Data Warehouse (BigQuery)
# The name of the BigQuery dataset created via Terraform
DATASET_NAME="nyc_311_analytics"

# 4. Local Authentication (Optional/Info)
# Note: If running via the provided Docker instructions in the README, 
# your local gcloud Application Default Credentials (ADC) will be mounted 
# automatically. No need to specify a JSON key path here for local execution.
