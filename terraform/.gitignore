# Terraform state (contains sensitive resource IDs — never commit)
*.tfstate
*.tfstate.backup
*.tfstate.*.backup

# Terraform working directory (downloaded providers, modules)
.terraform/
.terraform.lock.hcl

# Variable files with real values (keep .tfvars.example in git, not actual .tfvars)
*.tfvars
!terraform.tfvars.example

# Crash log files generated by Terraform providers
crash.log
crash.*.log

# Sensitive variable override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
